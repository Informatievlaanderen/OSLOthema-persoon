              "type": "string",
              "minLength": 10,
              "maxLength": 36
            }
          }
        ],
        "responses": {
          "200": {
            "description": "GeregistreerdPersoon object gevonden.",
            "content": {
              "application/ld+json": {
                "schema": { "$ref": "components.json#/components/schemas/VdipEnvelope" }
              }
            }
          },
          "400": {
            "description": "Invalid data supplied.",
