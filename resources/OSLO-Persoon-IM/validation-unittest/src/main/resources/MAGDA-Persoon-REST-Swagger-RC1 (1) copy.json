        "parameters": [
          {
            "name": "X-INSZ",
            "required": true,
            "in": "header",
            "description": "INSZ van een GeregistreerdPersoon object.",
            "schema": {
              "type": "string",
              "pattern": "^\\d{11}$"
            }
          },
          {
            "name": "X-Correlation-Id",
            "required": true,
            "in": "header",
            "description": "Correlatie ID van het request.",
