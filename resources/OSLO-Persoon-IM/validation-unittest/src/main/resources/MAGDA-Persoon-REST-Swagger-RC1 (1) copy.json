              "application/ld+json": {
                "schema": { "$ref": "components.json#/components/schemas/GeregistreerdPersoonJsonLd" }
              }
            },
            "links": {
              "Persoon.contactinfo": {
                "operationId": "PersoonGET",
                "parameters": {
                  "id": "$response.body#/Persoon.contactinfo/@id"
                },
                "description": "De waarde van het attribuut `@id` kan gebruikt worden om het gerefereerde object van het type `Contactinfo` op te halen."
              },
              "Persoon.geslacht": {
